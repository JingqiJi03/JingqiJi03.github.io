    <script is:inline>
      (() => {
        // ========== 数据 ==========
        const wordSets = {
          shared: {
            large: ["是啊", "对的", "真的", "我的天哪", "笑死了", "对啊对啊", "哈哈哈哈"],
            medium: ["好吧", "我服了", "嗯嗯", "嘿嘿", "笑死我了", "对的对的", "是的", "我感觉", "是的是的", "确实", "对啊"],
            small: ["然后", "哈哈哈", "哈哈哈哈哈哈", "我真服了", "我靠", "宝宝", "我去", "哦哦哦", "啊？", "我的天", "是啊是啊", "(bushi)"],
          },
          mine: {
            large: ["咱就是说", "那必须的", "哈哈哈哈", "真的是", "是的哇"],
            medium: ["嘿嘿", "确实", "是的", "是啊", "是吧", "哈哈哈", "对的", "嗯嗯", "好的哇"],
            small: ["啊？", "我靠", "我发现", "哈哈"],
          },
          hers: {
            large: ["笑死了哈哈哈哈哈哈", "对啊对啊", "我的天哪", "好滴好滴", "好啊好啊"],
            medium: ["对啊", "真的", "hhhhhh", "是啊是啊", "对的对的", "所以", "但是", "我笑死了"],
            small: ["是不是吧", "我的天", "我服了", "就是", "哦哦哦哦"],
          },
        };

        // ========== IntersectionObserver ==========
        const pages = document.querySelectorAll(".page");
        const observed = new Set();

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting && !observed.has(e.target)) {
                observed.add(e.target);
                e.target.classList.add("visible");
                animateCounters(e.target);
              }
            });
          },
          { threshold: 0.35 }
        );

        pages.forEach((p) => io.observe(p));

        // ========== 数字滚动 ==========
        function animateCounters(container) {
          const els = container.querySelectorAll(".counter[data-target]");
          els.forEach((el) => {
            if (el.dataset.animated) return;
            el.dataset.animated = "1";
            const target = parseFloat(el.dataset.target);
            const suffix = el.dataset.suffix || "";
            const decimal = parseInt(el.dataset.decimal) || 0;
            const duration = 1500;
            const start = performance.now();
            function tick(now) {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = eased * target;
              el.textContent =
                (decimal > 0 ? current.toFixed(decimal) : Math.round(current).toLocaleString()) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
          });
        }

        // ========== 常用语 Tab ==========
        const wordTabs = document.querySelectorAll(".word-tab");
        const wordCloud = document.getElementById("wordCloud");

        function renderWords(key) {
          const set = wordSets[key];
          wordCloud.innerHTML = "";
          set.large.forEach((w) => { const s = document.createElement("span"); s.className = "word-item word-large"; s.textContent = w; wordCloud.appendChild(s); });
          set.medium.forEach((w) => { const s = document.createElement("span"); s.className = "word-item word-medium"; s.textContent = w; wordCloud.appendChild(s); });
          set.small.forEach((w) => { const s = document.createElement("span"); s.className = "word-item word-small"; s.textContent = w; wordCloud.appendChild(s); });
        }

        wordTabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            wordTabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");
            renderWords(tab.dataset.tab);
          });
        });

        // ========== 继续 按钮 ==========
        document.getElementById("continueBtn")?.addEventListener("click", () => {
          const confession = document.querySelector('[data-page="10"]');
          if (confession) confession.scrollIntoView({ behavior: "smooth" });
        });

        // ========== 我再想想 按钮 ==========
        const thinkTexts = [
          "没关系，我可以等你。",
          "那我还能继续喜欢你吗？",
          "好，那先把这份报告送给你。",
        ];
        let thinkCount = 0;
        const btnThink = document.getElementById("btnThink");
        const thinkResponse = document.getElementById("thinkResponse");

        btnThink?.addEventListener("click", () => {
          thinkResponse.style.display = "block";
          thinkResponse.textContent = thinkTexts[Math.min(thinkCount, thinkTexts.length - 1)];
          thinkResponse.classList.add("fade-up");
          thinkCount++;
          if (thinkCount >= thinkTexts.length) {
            btnThink.textContent = "💗";
          }
        });

        // ========== 愿意 按钮 ==========
        document.getElementById("btnYes")?.addEventListener("click", () => {
          const successPage = document.getElementById("pageSuccess");
          const easterPage = document.getElementById("pageEaster");
          successPage.classList.add("show");
          io.observe(successPage);
          spawnConfetti();
          setTimeout(() => {
            easterPage.classList.add("show");
            io.observe(easterPage);
          }, 600);
          setTimeout(() => {
            successPage.scrollIntoView({ behavior: "smooth" });
          }, 300);
        });

        // ========== 撒花 ==========
        function spawnConfetti() {
          const colors = ["#c4876a", "#e8b4a0", "#c9a46a", "#f5c6bb", "#d4627a", "#f5a0b5", "#e0988c", "#a58661", "#c8b59e"];
          for (let i = 0; i < 60; i++) {
            const piece = document.createElement("div");
            piece.className = "confetti-piece";
            piece.style.background = colors[Math.floor(Math.random() * colors.length)];
            piece.style.left = Math.random() * 100 + "vw";
            piece.style.top = "-10px";
            const size = 4 + Math.random() * 8;
            piece.style.width = size + "px";
            piece.style.height = size + "px";
            piece.style.borderRadius = Math.random() > 0.5 ? "50%" : "2px";
            document.body.appendChild(piece);
            const duration = 2000 + Math.random() * 2500;
            const xDrift = (Math.random() - 0.5) * 200;
            piece.animate(
              [
                { transform: "translateY(0) translateX(0) rotate(0deg)", opacity: 1 },
                { transform: `translateY(100vh) translateX(${xDrift}px) rotate(${360 + Math.random() * 360}deg)`, opacity: 0 },
              ],
              { duration, easing: "cubic-bezier(0.25, 0.46, 0.45, 0.94)" }
            ).onfinish = () => piece.remove();
          }
        }
      })();
    </script>
  </body>
