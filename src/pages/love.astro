---
/**
 * 2026 双人聊天报告 · 心动报告
 *
 * 13 页纵向滚动网页
 * 所有内容在顶部配置区修改
 */

// ========== 内容配置 ==========
const daysSince = 46; // 距第一次遇见天数
const myName = "璟琦";
const herName = "昞润";

const data = {
  firstMeet: "2026/04/05",
  mostActiveDay: "周二",
  mostActiveTime: "21:00",
  mostActiveCount: 1134,
  emotionalBalance: { me: 57.1, her: 42.9 },
  fastestReply: "1 秒",
  avgReply: "1 分",
  slowestReply: "10.6 时",
  interactions: 6417,
  longestStreak: 46,
  streakStart: "2026/04/05",
  streakEnd: "2026/05/20",
  totalMessages: 36862,
  totalWords: 1331431,
  images: 520,
  voices: 223,
  emojis: 1382,
  myEmojiCount: 17,
  herEmojiCount: 12,
};

const wordSets = {
  shared: {
    large: ["是啊", "对的", "真的", "我的天哪", "笑死了", "对啊对啊", "哈哈哈哈"],
    medium: ["好吧", "我服了", "嗯嗯", "嘿嘿", "笑死我了", "对的对的", "是的", "我感觉", "是的是的", "确实", "对啊"],
    small: ["然后", "哈哈哈", "哈哈哈哈哈哈", "我真服了", "我靠", "宝宝", "我去", "哦哦哦", "啊？", "我的天", "是啊是啊", "(bushi)"],
  },
  mine: {
    large: ["咱就是说", "那必须的", "哈哈哈哈", "真的是", "是的哇"],
    medium: ["嘿嘿", "确实", "是的", "是啊", "是吧", "哈哈哈", "对的", "嗯嗯", "好的哇"],
    small: ["啊？", "我靠", "我发现", "哈哈"],
  },
  hers: {
    large: ["笑死了哈哈哈哈哈哈", "对啊对啊", "我的天哪", "好滴好滴", "好啊好啊"],
    medium: ["对啊", "真的", "hhhhhh", "是啊是啊", "对的对的", "所以", "但是", "我笑死了"],
    small: ["是不是吧", "我的天", "我服了", "就是", "哦哦哦哦"],
  },
};
// ========== 结束配置 ==========
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>520 告白页 · 璟琦 & 昞润</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,700;9..40,900&family=Noto+Serif+SC:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f7f3ec;
        --text: #2e2a26;
        --text-light: #9a8e82;
        --accent: #a58661;
        --accent-deep: #8f6f4e;
        --accent-light: #c8b59e;
        --brown: #9b7a55;
        --rose: #c4876a;
        --card-bg: rgba(255, 255, 255, 0.72);
        --font-display: "DM Sans", system-ui, sans-serif;
        --font-serif: "Noto Serif SC", serif;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        scroll-snap-type: y mandatory;
        scroll-behavior: smooth;
      }

      html, body {
        width: 100%;
        background: var(--bg);
        font-family: var(--font-serif);
        color: var(--text);
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        overflow-x: hidden;
      }

      /* ========== 通用页样式 ========== */
      .page {
        min-height: 100vh;
        scroll-snap-align: start;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
        position: relative;
        overflow: hidden;
      }

      .page-inner {
        max-width: 520px;
        width: 100%;
      }

      .section-label {
        font-family: var(--font-display);
        font-size: 0.7rem;
        font-weight: 400;
        letter-spacing: 0.2em;
        color: var(--accent);
        text-transform: uppercase;
        margin-bottom: 0.6rem;
      }

      .page-title {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(1.8rem, 6vw, 2.6rem);
        line-height: 1.2;
        color: var(--text);
        margin-bottom: 1.2rem;
      }

      .page-text {
        font-size: 0.95rem;
        line-height: 2;
        color: var(--text-light);
      }

      .page-text strong {
        color: var(--brown);
        font-weight: 600;
      }

      /* ========== 动画基础 ========== */
      .fade-up {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.7s ease, transform 0.7s ease;
      }
      .fade-up.d1 { transition-delay: 0.15s; }
      .fade-up.d2 { transition-delay: 0.3s; }
      .fade-up.d3 { transition-delay: 0.45s; }
      .fade-up.d4 { transition-delay: 0.6s; }
      .fade-up.d5 { transition-delay: 0.75s; }
      .fade-up.d6 { transition-delay: 0.9s; }

      .page.visible .fade-up {
        opacity: 1;
        transform: translateY(0);
      }

      .scale-in {
        opacity: 0;
        transform: scale(0.7);
        transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .scale-in.d1 { transition-delay: 0.2s; }
      .scale-in.d2 { transition-delay: 0.4s; }
      .scale-in.d3 { transition-delay: 0.6s; }

      .page.visible .scale-in {
        opacity: 1;
        transform: scale(1);
      }

      .counter {
        font-family: var(--font-display);
        font-weight: 900;
        color: var(--brown);
      }

      /* ========== 第1页 封面 ========== */
      .page-cover {
        background: var(--bg);
        align-items: flex-start;
        padding-left: max(1.5rem, 8vw);
      }

      .page-cover .page-inner {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
      }

      .cover-top-label {
        font-family: var(--font-display);
        font-size: 0.7rem;
        font-weight: 400;
        letter-spacing: 0.25em;
        color: var(--text-light);
        margin-bottom: 2rem;
      }

      .cover-year {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: clamp(2rem, 8vw, 3.5rem);
        color: var(--text);
        line-height: 1;
      }

      .cover-main-title {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(2.5rem, 10vw, 4.5rem);
        color: var(--text);
        line-height: 1.1;
        margin-top: 0.2em;
      }

      .cover-names {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: clamp(1.2rem, 4vw, 1.6rem);
        color: var(--accent);
        margin-top: 1.5rem;
      }

      .cover-sub {
        font-size: 0.85rem;
        color: var(--text-light);
        margin-top: 1rem;
        line-height: 1.8;
      }

      .cover-scroll-hint {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.7rem;
        color: var(--text-light);
        letter-spacing: 0.1em;
        animation: float-hint 2.5s ease-in-out infinite;
      }

      @keyframes float-hint {
        0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.4; }
        50% { transform: translateX(-50%) translateY(-6px); opacity: 0.7; }
      }

      /* ========== 第2页 第一次遇见 ========== */
      .big-date {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(2.8rem, 12vw, 4.5rem);
        color: var(--text);
        letter-spacing: -0.02em;
        margin: 1rem 0;
      }

      .date-timeline {
        width: 100%;
        max-width: 280px;
        height: 2px;
        background: var(--accent-light);
        margin: 1.5rem 0;
        position: relative;
        overflow: hidden;
      }

      .date-timeline-fill {
        position: absolute;
        left: 0; top: 0;
        height: 100%;
        width: 0%;
        background: var(--accent);
        transition: width 1.5s ease;
      }

      .page.visible .date-timeline-fill { width: 100%; }

      /* ========== 第3页 情感天平 ========== */
      .balance-row {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin: 1.5rem 0;
        width: 100%;
        max-width: 400px;
      }

      .balance-side { text-align: center; flex: 1; }
      .balance-name { font-size: 0.85rem; color: var(--text-light); margin-bottom: 0.4rem; }
      .balance-pct { font-family: var(--font-display); font-weight: 900; font-size: clamp(2rem, 8vw, 3rem); color: var(--text); }

      .balance-bar-wrap { width: 100%; max-width: 400px; margin: 1rem 0; }

      .balance-bar {
        width: 100%; height: 8px; border-radius: 4px;
        overflow: hidden; display: flex; background: #eee8dd;
      }

      .balance-bar-me {
        height: 100%; width: 0%;
        background: var(--accent);
        transition: width 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        border-radius: 4px 0 0 4px;
      }

      .balance-bar-her {
        height: 100%; width: 0%;
        background: var(--accent-light);
        transition: width 1.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s;
        border-radius: 0 4px 4px 0;
      }

      .page.visible .balance-bar-me { width: 57.1%; }
      .page.visible .balance-bar-her { width: 42.9%; }

      /* ========== 第4页 回复速度 ========== */
      .reply-cards {
        display: flex;
        align-items: flex-end;
        gap: 1.2rem;
        margin: 1.5rem 0;
        width: 100%;
        max-width: 420px;
      }

      .reply-card { text-align: center; flex: 1; }
      .reply-card-center { flex: 1.4; }
      .reply-card .reply-label { font-size: 0.7rem; color: var(--text-light); margin-bottom: 0.5rem; letter-spacing: 0.05em; }

      .reply-circle {
        width: 80px; height: 80px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 0.4rem;
        background: rgba(237, 226, 210, 0.4);
      }

      .reply-circle-main {
        width: 120px; height: 120px;
        background: radial-gradient(circle, #ede2d2 0%, rgba(237,226,210,0) 70%);
      }

      .reply-value { font-family: var(--font-display); font-weight: 900; font-size: 1.4rem; color: var(--text); }
      .reply-value-main { font-size: 2rem; }

      /* ========== 第5页 连续聊天 ========== */
      .streak-number {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(5rem, 20vw, 9rem);
        line-height: 1;
        color: var(--text);
      }

      .streak-unit {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: clamp(1.2rem, 4vw, 1.8rem);
        color: var(--accent);
        letter-spacing: 0.15em;
        margin-top: 0.2rem;
      }

      .streak-glow {
        position: absolute;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(165,134,97,0.1) 0%, transparent 70%);
        pointer-events: none;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%) scale(0.5);
        transition: transform 1.5s ease;
      }

      .page.visible .streak-glow { transform: translate(-50%, -50%) scale(1.5); }

      .streak-timeline {
        display: flex; align-items: center; gap: 0.5rem;
        margin-top: 2rem; width: 100%; max-width: 300px;
      }

      .streak-timeline-line {
        flex: 1; height: 2px; background: var(--accent-light);
        position: relative; overflow: hidden;
      }

      .streak-timeline-fill {
        position: absolute; left: 0; top: 0;
        height: 100%; width: 0%;
        background: #c9a46a;
        transition: width 2s ease;
      }

      .page.visible .streak-timeline-fill { width: 100%; }

      .streak-timeline-date {
        font-family: var(--font-display);
        font-size: 0.65rem;
        color: var(--text-light);
        white-space: nowrap;
      }

      /* ========== 第6页 常用语 ========== */
      .word-tabs {
        display: flex; gap: 0.5rem;
        margin: 1rem 0 1.5rem; flex-wrap: wrap;
      }

      .word-tab {
        padding: 0.4rem 1rem;
        border-radius: 999px;
        font-size: 0.75rem;
        border: 1px solid var(--accent-light);
        color: var(--text-light);
        background: transparent;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .word-tab.active {
        background: #fff;
        color: var(--brown);
        border-color: #fff;
        box-shadow: 0 2px 12px rgba(80, 60, 40, 0.1);
      }

      .word-cloud {
        display: flex; flex-wrap: wrap;
        gap: 0.6rem 0.8rem;
        justify-content: center;
        padding: 1rem 0;
        min-height: 120px;
      }

      .word-item {
        transition: opacity 0.3s, transform 0.3s;
        cursor: default;
      }

      .word-item:hover { transform: scale(1.1); }

      .word-large { font-size: 1.2rem; font-weight: 700; color: #3a332d; }
      .word-medium { font-size: 0.95rem; font-weight: 600; color: #8d7359; }
      .word-small { font-size: 0.8rem; font-weight: 400; color: #b7a694; }

      /* ========== 第7页 数据概览 ========== */
      .data-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 1.5rem; margin: 1.5rem 0;
        width: 100%; max-width: 420px;
      }

      .data-item { text-align: center; }

      .data-number {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(1.8rem, 6vw, 2.5rem);
        color: var(--brown);
        line-height: 1.2;
      }

      .data-label { font-size: 0.75rem; color: var(--text-light); margin-top: 0.2rem; }

      .data-row-three {
        grid-column: 1 / -1;
        display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;
      }

      /* ========== 第8页 表情包 ========== */
      .sticker-wrap {
        display: flex; justify-content: center; gap: 1.5rem;
        margin: 1.5rem 0;
      }

      .sticker-card {
        background: var(--card-bg);
        border-radius: 20px;
        box-shadow: 0 8px 28px rgba(80, 60, 40, 0.08);
        padding: 1rem 1.2rem 1.2rem;
        text-align: center;
      }

      .sticker-name {
        font-size: 0.75rem;
        color: var(--text-light);
        margin-bottom: 0.6rem;
      }

      .sticker-img {
        max-width: 140px;
        max-height: 140px;
        border-radius: 12px;
        object-fit: contain;
      }

      /* ========== 第9页 谢谢 ========== */
      .letter-page { text-align: center; }
      .letter-page .page-text { text-align: left; line-height: 2.2; }
      .highlight-num { color: var(--brown); font-weight: 600; }

      /* ========== 第10页 我想告诉你 ========== */
      .letter-card {
        background: rgba(255, 255, 255, 0.65);
        border-radius: 28px;
        padding: 2rem 1.8rem;
        margin: 1rem 0;
        width: 100%; max-width: 440px;
      }

      .letter-card .page-text { line-height: 2.2; }
      .letter-card .page-text p { margin-bottom: 0.8em; }

      .continue-btn {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.7rem 2.5rem;
        border-radius: 999px;
        background: var(--brown);
        color: #fff;
        font-family: var(--font-serif);
        font-size: 0.9rem;
        cursor: pointer;
        border: none;
        transition: transform 0.3s ease;
      }

      .continue-btn:active { transform: scale(0.96); }

      /* ========== 第11页 表白 ========== */
      .page-confession { background: linear-gradient(170deg, #f7f3ec 0%, #f0e4d8 100%); }

      .confession-big {
        font-family: var(--font-serif);
        font-weight: 700;
        font-size: clamp(2rem, 9vw, 3.2rem);
        color: var(--text);
        margin-bottom: 1rem;
        text-align: center;
      }

      .confession-sub {
        font-size: 0.9rem; color: var(--text-light);
        text-align: center; max-width: 300px;
        line-height: 1.8; margin-bottom: 2rem;
      }

      .confession-question {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: 1.2rem;
        color: var(--text);
        margin-bottom: 2rem;
        text-align: center;
      }

      .confession-btns {
        display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
      }

      .btn-yes {
        padding: 0.8rem 3rem;
        border-radius: 999px;
        background: var(--brown);
        color: #fff;
        font-family: var(--font-serif);
        font-size: 0.95rem;
        cursor: pointer;
        border: none;
        transition: transform 0.3s ease;
      }

      .btn-yes:active { transform: scale(0.96); }

      .btn-think {
        padding: 0.8rem 2rem;
        border-radius: 999px;
        background: transparent;
        border: 1px solid var(--accent-light);
        color: #8d7359;
        font-family: var(--font-serif);
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.4s ease;
        min-width: 140px;
        text-align: center;
      }

      .btn-think:active { transform: scale(0.96); }

      .heart-deco {
        position: absolute; pointer-events: none; opacity: 0;
        transition: opacity 1s ease;
      }

      .page.visible .heart-deco { opacity: 0.12; }

      /* ========== 第12页 成功 ========== */
      .page-success {
        display: none;
        background: linear-gradient(170deg, #faf6f1 0%, #f5ece2 100%);
      }

      .page-success.show { display: flex; }

      .success-title {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(1.6rem, 5vw, 2.2rem);
        color: var(--text);
        margin-bottom: 1rem;
      }

      .success-big-text {
        font-family: var(--font-serif);
        font-size: clamp(1.1rem, 3.5vw, 1.4rem);
        color: var(--text);
        line-height: 1.8;
        margin-bottom: 2rem;
        text-align: center;
      }

      .cert-card {
        background: #fff;
        border: 1.5px solid var(--accent-light);
        border-radius: 20px;
        padding: 2rem 1.5rem;
        width: 100%; max-width: 380px;
        box-shadow: 0 12px 40px rgba(80, 60, 40, 0.08);
      }

      .cert-title {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--accent);
        letter-spacing: 0.1em;
        text-align: center;
        margin-bottom: 1.2rem;
        padding-bottom: 0.8rem;
        border-bottom: 1px solid rgba(200, 181, 158, 0.3);
      }

      .cert-row {
        display: flex; justify-content: space-between;
        padding: 0.5rem 0; font-size: 0.85rem;
      }

      .cert-key { color: var(--text-light); }
      .cert-val { color: var(--text); font-weight: 600; }
      .cert-val.confirmed { color: var(--accent); }

      .cert-note {
        text-align: center;
        font-size: 0.75rem;
        color: var(--text-light);
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid rgba(200, 181, 158, 0.3);
      }

      .success-footer {
        font-size: 0.85rem; color: var(--text-light);
        margin-top: 2rem; text-align: center; line-height: 1.8;
      }

      /* ========== 第13页 彩蛋 ========== */
      .page-easter { display: none; background: var(--bg); }
      .page-easter.show { display: flex; }

      .easter-title {
        font-family: var(--font-serif);
        font-weight: 700;
        font-size: clamp(1.3rem, 4.5vw, 1.8rem);
        color: var(--text);
        margin-bottom: 1.5rem;
      }

      .easter-cards {
        display: flex; flex-direction: column; gap: 1rem;
        width: 100%; max-width: 400px;
      }

      .easter-card {
        background: rgba(255, 255, 255, 0.6);
        border-radius: 16px;
        padding: 1.2rem 1.4rem;
        box-shadow: 0 4px 20px rgba(80, 60, 40, 0.05);
      }

      .easter-card-title {
        font-family: var(--font-display);
        font-weight: 900;
        font-size: 1.1rem;
        color: var(--brown);
        margin-bottom: 0.4rem;
      }

      .easter-card-text { font-size: 0.85rem; color: var(--text-light); line-height: 1.8; }

      .easter-end { text-align: center; margin-top: 2rem; }
      .easter-end-line1 { font-family: var(--font-display); font-weight: 300; font-size: 0.85rem; color: var(--text-light); letter-spacing: 0.1em; }
      .easter-end-line2 { font-family: var(--font-serif); font-size: 0.9rem; color: var(--accent); margin-top: 0.3rem; }

      /* ========== 撒花 ========== */
      .confetti-piece { position: fixed; pointer-events: none; z-index: 200; }

      /* ========== 响应式 ========== */
      @media (max-width: 400px) {
        .reply-cards { gap: 0.6rem; }
        .reply-circle { width: 60px; height: 60px; }
        .reply-circle-main { width: 90px; height: 90px; }
        .emoji-cards { flex-direction: column; }
      }

      @media print { body { display: none; } }
    </style>
  </head>
  <body>
    <!-- ====== 第1页 封面 ====== -->
    <section class="page page-cover" data-page="0">
      <div class="page-inner">
        <div class="cover-top-label fade-up">MAY 20 &middot; CONFESSION</div>
        <div class="cover-year fade-up d1">特别的日子</div>
